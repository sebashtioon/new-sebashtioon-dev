---
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"vaultage">;
}

const { entry } = Astro.props;
const { data } = entry;
---

<article
  class="group relative h-[15.5rem] w-40 border border-ctp-surface0 bg-ctp-base/60 p-2"
>
  <a href={`/vaultage/${entry.id}/`} class="flex h-full flex-col gap-2">
    <div class="aspect-square bg-ctp-crust text-sm text-ctp-subtext0">
      {
        data.cover ? (
          <img
            src={data.cover}
            alt={`${data.album} album cover`}
            class="h-full w-full object-cover"
            loading="lazy"
          />
        ) : (
          <div class="flex h-full items-end bg-ctp-surface0 p-3">cover goes here</div>
        )
      }
    </div>

    <div class="min-h-0 flex-1">
      <div class="min-w-0">
        <p class="truncate text-xs text-ctp-subtext0">{data.artist}</p>
        <h2 class="line-clamp-2 font-inter text-sm font-bold leading-tight text-ctp-text">
          {data.album}
        </h2>
      </div>
      <p class="absolute bottom-2 left-2 w-fit bg-ctp-mauve px-2 py-1 font-inter text-xs font-bold text-ctp-crust">
        {data.rating}/10
      </p>
    </div>
  </a>
</article>

---
import { getCollection } from "astro:content";
import AlbumCard from "../../components/AlbumCard.astro";
import Layout from "../../layouts/Layout.astro";

const albums = (await getCollection("vaultage"))
  .filter((entry) => entry.data.status === "published")
  .sort((a, b) => b.data.rating - a.data.rating);

const averageRating = albums.length
  ? albums.reduce((total, album) => total + album.data.rating, 0) / albums.length
  : 0;

const albumCount = albums.filter((entry) => entry.data.releaseType === "album").length;
const epCount = albums.filter((entry) => entry.data.releaseType === "ep").length;
---

<Layout
  title="the vaultage"
  headerTitle="the vaultage"
  headerDescription="my music collection"
>
  <aside class="mt-5 flex flex-wrap gap-x-4 gap-y-1 text-sm text-ctp-subtext0">
    <p><span class="text-ctp-text">{albums.length}</span> albums logged</p>
    <p><span class="text-ctp-text">{averageRating.toFixed(1)}</span> average rating</p>
  </aside>

  <div class="mt-4 flex flex-wrap gap-2" aria-label="Filter releases">
    <button class="bg-ctp-surface0 px-4 py-2" type="button" data-release-filter="album">
      albums ({albumCount})
    </button>
    <button class="bg-ctp-surface0 px-4 py-2" type="button" data-release-filter="ep">
      eps ({epCount})
    </button>
  </div>

  <section class="mt-4 flex flex-wrap gap-3" data-release-list>
    {
      albums.map((entry) => (
        <div data-release-type={entry.data.releaseType}>
          <AlbumCard entry={entry} />
        </div>
      ))
    }
  </section>

  <script>
    const filterButtons = document.querySelectorAll<HTMLButtonElement>("[data-release-filter]");
    const releaseItems = document.querySelectorAll<HTMLElement>("[data-release-type]");

    const showReleaseType = (releaseType: string) => {
      releaseItems.forEach((item) => {
        item.hidden = item.dataset.releaseType !== releaseType;
      });
    };

    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        showReleaseType(button.dataset.releaseFilter ?? "album");
      });
    });

    showReleaseType("album");
  </script>
</Layout>
